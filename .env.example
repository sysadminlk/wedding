# ===========================================
# weddingWire Environment Variables
# ===========================================
# Copy this to .env and fill in production values
# NEVER commit .env to git

# ---- Spring ----
SPRING_PROFILES_ACTIVE=production

# ---- Database ----
POSTGRES_DB=weddingwire
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/weddingwire
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme

# ---- JWT ----
JWT_SECRET=changeme-generate-a-random-32-char-string

# ---- SMTP Email ----
SMTP_HOST=mail.datacenter.lk
SMTP_PORT=587
SMTP_USERNAME=inbox@weddingwire.lk
SMTP_PASSWORD=changeme
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@weddingwire.lk

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- Apple OAuth (TODO) ----
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ---- PayHere ----
PAYHERE_MERCHANT_ID=your-payhere-merchant-id
PAYHERE_SECRET=your-payhere-secret
PAYHERE_SANDBOX=true
PAYHERE_NOTIFY_URL=https://backend.weddingwire.lk/api/payments/webhook/payhere

# ---- notify.lk SMS ----
SMS_ENABLED=true
NOTIFY_LK_USER_ID=your-notify-lk-user-id
NOTIFY_LK_API_KEY=your-notify-lk-api-key
NOTIFY_LK_SENDER_ID=CheerMe.lk

# ---- Twilio SMS (disabled, using notify.lk) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- WhatsApp Business (TODO) ----
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ---- S3 / MinIO ----
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_BUCKET=weddingwire
AWS_S3_PATH_STYLE=true

# ---- Domain ----
APP_DOMAIN=weddingwire.lk
APP_FRONTEND_URL=https://app.weddingwire.lk
APP_BACKEND_URL=https://backend.weddingwire.lk

# ---- Web (Next.js) ----
BACKEND_URL=http://backend:7070
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---- Demo Mode ----
DEMO_ENABLED=true
DEMO_RESET_CRON=0 0 2 * * *
